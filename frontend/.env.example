# ============================================
# Frontend Environment Variables
# ============================================
# Name your bakery
VITE_APP_NAME=Bánh Kem Online

# API URL - In development: http://localhost:5000/api
#             In production (same domain): /api (relative)
#             In production (separate domain): https://api.your-app.onrender.com/api
VITE_API_URL=http://localhost:5000/api

# Admin email (must match backend ADMIN_EMAIL)
VITE_ADMIN_EMAIL=admin@banhkem.com

# Enable admin demo button in development only
VITE_ENABLE_ADMIN_DEMO=false

# Cloudinary (for image uploads - optional)
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name