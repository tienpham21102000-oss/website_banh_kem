# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=5000

# In development: http://localhost:5000
# In production: https://your-app.onrender.com
API_BASE_URL=https://your-app.onrender.com

# In production: https://your-app.onrender.com (same domain when serving static frontend)
FRONTEND_URL=https://your-app.onrender.com

# Session secret for OAuth handshake (REQUIRED in production!)
SESSION_SECRET=replace_me_with_a_secure_random_string

# ============================================
# Database (PostgreSQL)
# ============================================
# Render PostgreSQL Internal Connection String (from Render Dashboard)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:port/database_name
PGSSLMODE=require

# ============================================
# JWT Authentication
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# Facebook OAuth (Meta for Developers)
# ============================================
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
# Optional: override the auto-detected callback URL
# FACEBOOK_CALLBACK_URL=https://your-app.onrender.com/api/auth/facebook/callback

# ============================================
# VNPay (Sandbox / Demo)
# ============================================
VNPAY_TMN_CODE=DEMO_CODE
VNPAY_HASH_SECRET=DEMO_SECRET
VNPAY_API_URL=http://localhost:5000/api/payments/demo
VNPAY_RETURN_URL=https://your-app.onrender.com/checkout/return

# ============================================
# SendGrid (Email Notifications - Optional)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@banhkem.com

# ============================================
# Admin Account
# ============================================
ADMIN_EMAIL=admin@banhkem.com
ADMIN_PASSWORD=replace_me_in_production

# ============================================
# Features
# ============================================
MIN_DELIVERY_ADVANCE_HOURS=48
CART_EXPIRY_DAYS=30
SESSION_EXPIRY_DAYS=7